<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.unhero.magisterial.monitor</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/miniconda3/bin/python3</string>
        <string>/Users/kennethdallmier/magisterial-manifold/GridDefense/manifold_monitor.py</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardErrorPath</key>
    <string>/Users/kennethdallmier/Library/Logs/Magisterium/monitor_err.log</string>
    <key>StandardOutPath</key>
    <string>/Users/kennethdallmier/Library/Logs/Magisterium/monitor_out.log</string>
    <key>WorkingDirectory</key>
    <string>/Users/kennethdallmier/magisterial-manifold</string>
</dict>
</plist>
